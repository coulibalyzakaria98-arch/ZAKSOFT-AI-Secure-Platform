{
  "buildCommand": "npm run build && mv dist/index.html dist/app.html",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://zaksoft-backend.onrender.com/api/:path*"
    },
    {
      "source": "/",
      "destination": "/landing.html"
    },
    {
      "source": "/(.*)",
      "destination": "/app.html"
    }
  ],
  "env": {
    "VITE_API_URL": ""
  }
}
